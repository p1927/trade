# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
# Required for Vibe Trading when TRADINGAGENTS_LLM_PROVIDER=minimax
#MINIMAX_BASE_URL=https://api.minimax.io/v1
# Hub news entity distillation (staging queue → verified events). Default on.
#HUB_NEWS_ENTITY_PIPELINE=1
# Sync-distill N items per ingest burst before deferring to background drain (default 10)
#HUB_NEWS_SYNC_DISTILL_LIMIT=10
# Pause staging enqueue when queue depth exceeds threshold (default 400)
#HUB_NEWS_BACKPRESSURE_THRESHOLD=400
# Continuous entity drain every 15 min with adaptive batch (default on)
#HUB_NEWS_ENTITY_CONTINUOUS_ENABLED=1
#HUB_NEWS_ENTITY_CONTINUOUS_CRON=*/15 * * * *
# Semantic merge threshold for entity worker + daily compaction (default 0.72)
#HUB_NEWS_DEDUP_SUMMARY_THRESHOLD=0.72

# LLM Wiki desktop app (local API http://127.0.0.1:19828) — hub project at reports/hub/llm-wiki/
# Open/create project in LLM Wiki app at that path, then sync id from GET /api/v1/projects
#LLM_WIKI_BASE_URL=http://127.0.0.1:19828
#LLM_WIKI_PROJECT_ID=
#LLM_WIKI_API_TOKEN=
# Export distilled events → raw/sources/news/ and batch-rescan for ingest (default on)
#HUB_NEWS_WIKI_COMPILE=1
# Tier-2 staging dedup via LLM Wiki embedding endpoint (default on)
#HUB_NEWS_USE_LLM_WIKI_EMBEDDINGS=1
#HUB_NEWS_EMBED_CLUSTER_THRESHOLD=0.80
#HUB_NEWS_EMBED_ENDPOINT=
#HUB_NEWS_EMBED_MODEL=text-embedding-3-small
#HUB_NEWS_EMBED_API_KEY=
# Relevance gate for staging refs (default on, min confidence 0.60)
#HUB_NEWS_RELEVANCE_GATE=1
#HUB_NEWS_RELEVANCE_MIN_CONFIDENCE=0.60
#HUB_NEWS_RELEVANCE_RULE_FIRST=1
# Override LLM Wiki app-state path for embedding config (macOS default below)
#LLM_WIKI_APP_STATE_PATH=~/Library/Application Support/com.llmwiki.app/app-state.json

# NSE browser fetch module (nodriver + MiniMax agent)
#NSE_BROWSER_AUTO_INSTALL_CHROME=1
#NSE_BROWSER_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Headed browser (NSE blocks repeated open/close — use one session per backfill batch)
#NSE_BROWSER_HEADLESS=0
#NSE_BROWSER_MIN_INTERVAL_S=180
#NSE_BROWSER_INTRA_MISSION_INTERVAL_S=1
#NSE_BROWSER_PAGE_WAIT_S=0.8
#NSE_BROWSER_MISSION_TIMEOUT_S=55
#NSE_BROWSER_HISTORICAL_TIMEOUT_S=120
#NSE_BROWSER_ALLOW_DOWNLOAD_CLICK=0
#NSE_BROWSER_DOWNLOAD_TIMEOUT_S=25
#NSE_BROWSER_AGENT_VISION=0
#NSE_BROWSER_AGENT_MODEL=MiniMax-M3
#NSE_BROWSER_ON_REFRESH=1
#NSE_BROWSER_WEB_FLOW_ON_REFRESH=1
#NSE_BROWSER_WEB_FLOW_BROWSER=0
#WEB_FLOW_MONTHS_BACK=18
#NSE_BROWSER_WEB_FLOW_TIMEOUT_S=120
#NSE_BROWSER_AGENT_DISABLED=0
# Rescue chain: nodriver deterministic → MiniMax operator → MiniMax extract
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Local SearXNG instance for news search (used by the news aggregator)
#SEARXNG_BASE_URL=http://localhost:5556
# Merge multiple news backends (deduped). Set news_data vendor to "aggregated".
#TRADINGAGENTS_NEWS_DATA_VENDOR=aggregated
#TRADINGAGENTS_NEWS_AGGREGATOR_SOURCES=searxng,yfinance,alpha_vantage

# Extra RSS/Atom feeds for the Sentiment Analyst (appended to built-in Google
# News + Yahoo Finance defaults). Comma-separated label|url pairs; bare URLs
# work too. Use {ticker} or {search_term} in the URL for ticker-specific feeds.
#TRADINGAGENTS_SENTIMENT_RSS_FEEDS=Seeking Alpha|https://seekingalpha.com/api/sa/combined/{ticker}.rss,MarketWatch|https://www.marketwatch.com/rss/topstories

# FRED (Federal Reserve macro data: rates, inflation, labor, growth). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
#FRED_API_KEY=

# Cloudflare tunnel exposure for OpenAlgo webhooks (TradingView, GoCharting, Chartink)
#EXPOSURE_HOSTNAME=openalgo.yourdomain.com
#CLOUDFLARE_TUNNEL_NAME=trade-openalgo
#CLOUDFLARE_CONFIG=~/.cloudflared/config.yml

