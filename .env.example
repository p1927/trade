#HUB_NEWS_FETCH_ARTICLE_BODY=1
#HUB_NEWS_ARTICLE_MIN_SUMMARY_LEN=400
#HUB_NEWS_ARTICLE_MAX_CHARS=8000
#HUB_NEWS_ARTICLE_CACHE_DAYS=7
# Merge multiple news backends (deduped). Set news_data vendor to "aggregated".
#TRADINGAGENTS_NEWS_DATA_VENDOR=aggregated
#TRADINGAGENTS_NEWS_AGGREGATOR_SOURCES=searxng,yfinance,alpha_vantage

# Extra RSS/Atom feeds for hub ingest + sentiment analyst (appended to built-in Google
# News + Yahoo Finance defaults in rss_feeds.py). Comma-separated label|url pairs; bare
# URLs work too. Use {ticker} or {search_term} in URLs for symbol-specific feeds.
# When unset, India-focused defaults (Google News India, Moneycontrol, Yahoo) apply.
#TRADINGAGENTS_SENTIMENT_RSS_FEEDS=Google News India|https://news.google.com/rss/search?q={search_term}+NSE+stock+India&hl=en-IN&gl=IN&ceid=IN:en,Moneycontrol Latest|https://www.moneycontrol.com/rss/latestnews.xml,Yahoo Finance|https://feeds.finance.yahoo.com/rss/2.0/headline?s={ticker}&region=US&lang=en-US

# FRED (Federal Reserve macro data: rates, inflation, labor, growth). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
#FRED_API_KEY=

# Cloudflare tunnel exposure for OpenAlgo webhooks (TradingView, GoCharting, Chartink)
#EXPOSURE_HOSTNAME=openalgo.yourdomain.com
#CLOUDFLARE_TUNNEL_NAME=trade-openalgo
#CLOUDFLARE_CONFIG=~/.cloudflared/config.yml

