# Options research pipeline (index + F&O stock)
#TRADINGAGENTS_OPTIONS_LOOKAHEAD_DAYS=14
#TRADINGAGENTS_OPTIONS_CACHE_MINUTES=30
#TRADINGAGENTS_OPTIONS_PREFETCH=true
#INDEX_AUTO_WIDGET_ON_PREFETCH=false
#TRADINGAGENTS_INDEX_PREFETCH=true
#TRADINGAGENTS_STOCK_PREFETCH=true
#TRADINGAGENTS_OPTIONS_STRIKE_COUNT=15
#TRADINGAGENTS_OPTIONS_BROKER_PRESET=zerodha
# Vibe Trading Web UI (vibetrading/ submodule — pip install -e vibetrading/)
#VIBE_TRADING_ENABLED=true
#VIBE_BACKEND_PORT=8899
#VIBE_FRONTEND_PORT=5899
#VIBE_FRONTEND_DIR=vibetrading/frontend
#VIBE_TRADING_HOME=~/.vibe-trading
# After editing OPENALGO_* or LLM keys, re-sync Vibe config:
#   python scripts/setup_vibe.py --force-env
# Verify OpenAlgo MCP (options chain + orders in chat):
#   python scripts/setup_vibe.py --verify
# Shared context hub (company research + future Vibe context)
#TRADE_STACK_HUB_DIR=reports/hub
# TimescaleDB hot tick tier — sub-minute quotes during Nautilus watch; nightly export to hub parquet
# Start: docker compose -f docker-compose.stack.yml up -d timescaledb  (or ./start.sh)
TIMESCALE_ENABLED=true
TIMESCALE_DATABASE_URL=postgresql://postgres:tradehub@localhost:5433/trade_hub
TIMESCALE_HOT_RETENTION_DAYS=7
# Optional Postgres tuning for Docker (defaults in stack/timescaledb/postgresql.custom.conf):
#TIMESCALE_SHARED_BUFFERS=512MB
#TIMESCALE_MAX_WAL_SIZE=4GB
# Graceful stop: docker compose -f docker-compose.stack.yml stop timescaledb  (not docker kill)
# WAL replay after crash: ./scripts/repair_timescale.sh  — do not interrupt recovery
# Hub stores news + derivatives chain in _data/news/daily and _data/derivatives_chain/daily (evening job)
# Optional NSE→BSE scrip map for dalal BSE when NSE blocks scrapers (403):
#TRADINGAGENTS_BSE_CODE_MAP={"RELIANCE":"500325","TCS":"532540","INFY":"500209"}
# --- Optional research infra (all free / open-source) ---
#
# 1) SEC EDGAR filings (US) — FREE, no API key. SEC requires a descriptive User-Agent.
#    Set your real name + email (used by edgartools / finverse.pull.edgar).
#    Steps: add line below to .env → pip install "trade-stack[research]" (includes edgartools)
#    → python scripts/smoke_research_stage.py --stage filings_us --ticker AAPL
#SEC_EDGAR_IDENTITY=Your Name your@email.com
#
# 2) Finverse beat-probability (US earnings_signal) — FREE OSS, no API key.
#    Steps: pip install "trade-stack[research-plus]"  (adds finverse>=0.7)
#    → python scripts/smoke_research_stage.py --stage earnings_signal --ticker AAPL
#
# 3) SentimentPulse — FREE OSS FinBERT. Two modes (pick one):
#    A) In-process (lightest): no Docker, downloads ~400MB model on first run.
#       Steps: pip install transformers torch
#       → set SENTIMENT_PULSE_MODE=inprocess in .env
#       → python scripts/smoke_research_stage.py --stage sentiment --ticker AAPL
#    B) Full Docker stack (Kafka + TimescaleDB + API :8081 + dashboard :3001):
#       git clone https://github.com/Eomaxl/SentimentPulse ~/SentimentPulse
#       → cd ~/SentimentPulse && docker compose up -d
#       → optional GNEWS_API_KEY in SentimentPulse .env for extra RSS headlines
#       → set SENTIMENT_PULSE_URL=http://localhost:8081
#SENTIMENT_PULSE_MODE=inprocess
#SENTIMENT_PULSE_URL=http://localhost:8081
#SENTIMENT_PULSE_MODEL=EomaxlSam/finbert-finetuned-sentimentpulse
#
# 4) ED-ALPHA corp-event forecasts (US 8-K) — FREE OSS submodule at ed-alpha/
#    Fork: https://github.com/p1927/ED-ALPHA  Upstream: E9Technologies/ED-ALPHA
#    Quick setup from Trade root:
#    ./scripts/setup_ed_alpha.sh
#    → set ED_ALPHA_BASE_URL=http://localhost:8000
#    → python scripts/smoke_research_stage.py --stage corp_events --ticker AAPL
#    Full ranked predictions need batch GDELT ingest (see ed-alpha/README.md).
#    Start/stop: make start-ed-alpha / make stop-ed-alpha
#ED_ALPHA_BASE_URL=http://localhost:8000
# Tapetide MCP — always on when TAPETIDE_TOKEN is set (see company_research/source_registry.py)
#TAPETIDE_TOKEN=
#TAPETIDE_MCP_URL=https://mcp.tapetide.com/mcp
# Tiered API queue + hub cache (integrations/trade_integrations/tiered_api/)
#TIERED_API_ENABLED=1
#TIERED_API_HUB_TTL_HOURS=168
#TIERED_API_TAPETIDE_DAILY_LIMIT=100
#TIERED_API_ALPHA_VANTAGE_DAILY_LIMIT=25
#TIERED_API_ALPHA_VANTAGE_MIN_INTERVAL=12
#EOD_HISTORICAL_API_KEY=
#TIERED_API_EOD_HISTORICAL_DAILY_LIMIT=20
#TIERED_API_FINNHUB_DAILY_LIMIT=60
#TIERED_API_TIINGO_DAILY_LIMIT=50
#TIERED_API_FMP_DAILY_LIMIT=250
# Status: trade tiered-api status
# Nifty 50 batch always skips Tapetide (see company_research/fetch_policy.py).

# OpenAlgo bridge — live Indian market data via local OpenAlgo instance (Groww, etc.)
# Start OpenAlgo first (./start.sh --openalgo-only), log in, connect broker, generate API key.
# Default port is often 5001 when run via this stack's start.sh (5000 if you start OpenAlgo manually).
#OPENALGO_HOST=http://127.0.0.1:5001
#OPENALGO_API_KEY=
# Route Vibe widget Execute through OpenAlgo analyzer/sandbox (paper) — default true for safety
#OPENALGO_PAPER_MODE=true
# Hub channel WATCH policy TTL (seconds) — Nautilus poll loop, material alert thresholds
OPENALGO_WATCH_QUOTE_TTL_SECONDS=5
# OpenAlgo WebSocket proxy (seeds hub L1 cache for Nautilus WATCH; default on when websocket-client installed)
OPENALGO_WS_ENABLED=1
# OPENALGO_WS_URL=ws://127.0.0.1:8765

# Nautilus watch node — OpenAlgo feeds data; Nautilus watches/alerts; OpenAlgo executes intents
# Plan: docs/superpowers/plans/2026-07-16-nautilus-openalgo-bridge.md
# Setup: ./scripts/setup_nautilus.sh  (Python 3.12+ → .venv-nautilus)
#NAUTILUS_WATCH_ENABLE=true
#NAUTILUS_QUOTE_POLL_MS=2000
#NAUTILUS_WATCH_SYMBOLS=NIFTY,BANKNIFTY,INDIAVIX
#NAUTILUS_ALERT_COOLDOWN_SEC=300
#NAUTILUS_REDIS_URL=redis://127.0.0.1:6379/0
# Start with stack: docker compose -f docker-compose.stack.yml up -d redis timescaledb
# Or: ./start.sh (starts Redis + Timescale when NAUTILUS_WATCH_ENABLE / TIMESCALE_ENABLED)
#NAUTILUS_INSTANCE_ID=trade-watch-1
#NAUTILUS_AGENT_ID=aa_your_agent_id
# Start manually: trade start nautilus-watch --agent-id aa_your_agent_id
# Auto-started on India agent Confirm + trade up when a running agent exists
#NAUTILUS_PYTHON=python3.12

# Autonomous agents (/autonomous) — post-commit bootstrap + scheduler jobs
# Set in vibetrading/agent/.env (or root .env if your launcher merges them):
#VIBE_TRADING_ENABLE_SCHEDULER=1
#AUTONOMOUS_AGENTS_ENABLE_SCHEDULER=1

# Alpaca paper trading — US equities (quotes, history, paper orders)
# Get keys at https://app.alpaca.markets/ (Paper Trading tab). Used by:
#   - trade_integrations Alpaca vendor (US tickers before yfinance fallback)
#   - OpenAlgo MCP get_us_quote / get_us_paper_account tools
#   - Vibe Trading alpaca-paper-trade connector (~/.vibe-trading/alpaca.json via setup_vibe.py)
#ALPACA_API_KEY=
#ALPACA_API_SECRET=
#ALPACA_API_BASE=https://paper-api.alpaca.markets
#ALPACA_DATA_BASE=https://data.alpaca.markets
#ALPACA_PROFILE=paper
#ALPACA_DATA_FEED=iex
# Attach live quote to stock data when Alpaca is configured (IEX near-real-time)
#ALPACA_REALTIME_ENABLED=true
# Vendor chain when both OpenAlgo (IN) and Alpaca (US) are set:
#TRADINGAGENTS_CORE_STOCK_DATA_VENDOR=openalgo,alpaca,yfinance
#TRADINGAGENTS_TECHNICAL_INDICATORS_DATA_VENDOR=openalgo,alpaca,yfinance

# Automated intraday paper trading (OpenAlgo sandbox; max budget enforced in trade stack)
# Set starting_capital to match in OpenAlgo Sandbox UI (http://127.0.0.1:5001/sandbox/)
#AUTO_PAPER_TRADING_ENABLED=false
#AUTO_PAPER_ENABLE_SCHEDULER=false
#AUTO_PAPER_BUDGET_INR=20000
#AUTO_PAPER_MAX_DAILY_LOSS_INR=2000
#AUTO_PAPER_MIN_STRATEGY_SCORE=0.45
#AUTO_PAPER_WATCHLIST=NIFTY,BANKNIFTY
#AUTO_PAPER_POLL_CRON=*/5 * * * *
#AUTO_PAPER_PRODUCT=NRML
#AUTO_PAPER_MARKET_OPEN=09:20
#AUTO_PAPER_MARKET_CLOSE=15:10
#AUTO_PAPER_MAX_OPEN_POSITIONS=1
#AUTO_PAPER_MIN_HOLD_MINUTES=10
#AUTO_PAPER_POLL_INTERVAL_MS=300000
# Vibe backend URL for standalone paper agent script (default port 8899)
#VIBE_BACKEND_URL=http://127.0.0.1:8899
# Requires VIBE_TRADING_ENABLE_SCHEDULER=1 in vibetrading/agent/.env when using scheduler
# Stop paper session: stop_auto_paper_trading MCP or POST /trade/auto-paper/stop (removes auto-paper cron)
#TRADINGAGENTS_CORE_STOCK_DATA_VENDOR=openalgo,yfinance
#TRADINGAGENTS_TECHNICAL_INDICATORS_DATA_VENDOR=openalgo,yfinance
#TRADINGAGENTS_FUNDAMENTAL_DATA_VENDOR=yfinance

# Optional: a custom OpenAI-compatible endpoint (vLLM, LM Studio, llama.cpp,
# relay). Select provider "openai_compatible" and set the base URL; the key is
# optional (local servers need none).
#OPENAI_COMPATIBLE_API_KEY=

# AWS Bedrock (provider "bedrock", install with: pip install ".[bedrock]").
# Auth: either a Bedrock API key (bearer token, no AWS access keys) OR the AWS
# credential chain (env keys / ~/.aws/credentials / IAM role / AWS_PROFILE). Set
# the region either way; a bearer token takes precedence when both are present.
#AWS_BEARER_TOKEN_BEDROCK=
#AWS_DEFAULT_REGION=us-west-2
#AWS_PROFILE=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# In the CLI, setting the LLM provider / models / backend URL / language
# also skips the matching interactive selection step (useful for
# OpenAI-compatible endpoints like opencode or LM Studio, and unattended runs).
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false
# Sampling temperature (lower = less run-to-run variation on models that
# honor it). Unset leaves each provider at its default. See the README
# "Reproducibility" note — no setting makes LLM output fully deterministic.
#TRADINGAGENTS_TEMPERATURE=0.0
# LLM SDK retry budget forwarded to every provider. Unset leaves each SDK at its
# own default (usually 2). Raise it to ride out bursty 429 rate-limit throttling
# on rate-limited deployments (e.g. Azure OpenAI) instead of aborting the run.
#TRADINGAGENTS_LLM_MAX_RETRIES=6
# Provider-specific reasoning/thinking depth (optional; unset = provider
# default). Setting one also skips the matching interactive prompt.
#TRADINGAGENTS_OPENAI_REASONING_EFFORT=medium
#TRADINGAGENTS_GOOGLE_THINKING_LEVEL=high
#TRADINGAGENTS_ANTHROPIC_EFFORT=high

# Development (trade dev — auto-reload Vibe API, Vite HMR, OpenAlgo FLASK_DEBUG)
# Edit ports in stack/ports.yaml then: trade sync-ports
# After .env changes: trade reload env
#STACK_PORTS_STRICT=1

