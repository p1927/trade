# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
# Required for Vibe Trading when TRADINGAGENTS_LLM_PROVIDER=minimax
# Also used by external-predictions LLM extract (Miscellaneous tab) after Crawl4AI fetch
#MINIMAX_BASE_URL=https://api.minimax.io/v1
# Regional MiniMax endpoint (use your plan's base URL if not api.minimax.io/v1):
#MINIMAX_BASE_URL=https://minimax.io

# Crawl4AI parallel browser fetch for external predictions (Miscellaneous tab)
# Installed by: trade setup / ./scripts/ensure_crawl4ai.sh (host Playwright — not Docker)
CRAWL4AI_MAX_PARALLEL=2
# Optional: attach to local Chrome (must be running with --remote-debugging-port=9222)
#CRAWL4AI_CDP_URL=http://127.0.0.1:9222
# Optional: residential proxy for datacenter IPs (also reads HTTP_PROXY)
#CRAWL4AI_PROXY=http://user:pass@host:port
#CRAWL4AI_UNDETECTED=0
#CRAWL4AI_INTER_REQUEST_DELAY_SEC=2
#CRAWL4AI_DELAY_BEFORE_RETURN_HTML=3.5
# Hub news entity distillation (staging queue → verified events). Default on.
#HUB_NEWS_ENTITY_PIPELINE=1
# Sync-distill N items per ingest burst before deferring to background drain (default 10)
#HUB_NEWS_SYNC_DISTILL_LIMIT=10
# Light ingest queues refs only; entity drain cron distills (default 0).
#HUB_NEWS_LIGHT_SYNC_DISTILL_LIMIT=0
# MiniMax-M3: adaptive thinking on by default; reasoning_split keeps it out of answers.
#MINIMAX_REASONING_SPLIT=1
#MINIMAX_DISTILL_REASONING_SPLIT=1
#MINIMAX_THINKING_DISABLED=0
# Fact-first LLM adjudication + story dedup in entity drain (default on).
#HUB_NEWS_LLM_ADJUDICATION_ENABLED=1
#HUB_NEWS_LLM_ADJUDICATION_BATCH_SIZE=8
#HUB_NEWS_ADJUDICATION_DISCARD_CONTRADICTED=1
#HUB_NEWS_ADJUDICATION_DISCARD_HOAX=1
#MINIMAX_DISTILL_MAX_TOKENS=2048
# MiniMax-M3: use max_completion_tokens (max_tokens deprecated). Mapped in minimax_agent.
#MINIMAX_ADJUDICATION_MAX_TOKENS=8192
#MINIMAX_STORY_DEDUP_MAX_TOKENS=8192
#MINIMAX_DEFAULT_COMPLETION_TOKENS=4096
#MINIMAX_THINKING_DISABLED=0
# Legacy alias for MINIMAX_THINKING_DISABLED (set 1 only to disable reasoning):
#MINIMAX_JSON_THINKING_DISABLED=0
# When unset, adjudication runs in chunks of 4 refs per MiniMax call.
#HUB_NEWS_ADJUDICATION_CHUNK_SIZE=4
# Pause staging enqueue when queue depth exceeds threshold (default 400)
#HUB_NEWS_BACKPRESSURE_THRESHOLD=400
# Continuous entity drain every 15 min with adaptive batch (default on)
#HUB_NEWS_ENTITY_CONTINUOUS_ENABLED=1
#HUB_NEWS_ENTITY_CONTINUOUS_CRON=*/15 * * * *
# Semantic merge threshold for entity worker + daily compaction (default 0.72)
#HUB_NEWS_DEDUP_SUMMARY_THRESHOLD=0.72

# LLM Wiki desktop app (local API http://127.0.0.1:19828) — hub project at reports/hub/llm-wiki/
# Start LLM Wiki.app manually (Trade does not auto-launch). Open/create project at that path,
# then copy project id from GET /api/v1/projects into LLM_WIKI_PROJECT_ID below.
#LLM_WIKI_BASE_URL=http://127.0.0.1:19828
#LLM_WIKI_PROJECT_ID=
#LLM_WIKI_API_TOKEN=
# Block hub news ingest/drain when wiki probe fails (default on)
HUB_NEWS_REQUIRE_LLM_WIKI=1
# Expire queued staging refs after N days when wiki blocks ingest (default 7)
HUB_NEWS_STAGING_TTL_DAYS=7
# T4 gray-zone resolver (MiniMax) for ambiguous match scores 0.60–0.72 (default on)
HUB_NEWS_RESOLVER_AGENT_ENABLED=1
HUB_NEWS_RESOLVER_AGENT_GRAY_LOW=0.60
HUB_NEWS_RESOLVER_AGENT_MAX_PER_DRAIN=10
HUB_NEWS_RESOLVER_AGENT_MODEL=MiniMax-M3
# Post-upsert two-signal duplicate scan in 7-day window (Phase 4, default on)
HUB_NEWS_POST_UPSERT_SAFETY_SCAN=1
HUB_NEWS_POST_UPSERT_LOOKBACK_DAYS=7
# Export distilled events → raw/sources/news/ and batch-rescan for ingest (default on)
HUB_NEWS_WIKI_COMPILE=1
# Tier-2 staging dedup via LLM Wiki embedding endpoint (default on)
HUB_NEWS_USE_LLM_WIKI_EMBEDDINGS=1
#HUB_NEWS_EMBED_CLUSTER_THRESHOLD=0.80
#HUB_NEWS_EMBED_ENDPOINT=
#HUB_NEWS_EMBED_MODEL=text-embedding-3-small
#HUB_NEWS_EMBED_API_KEY=
# Relevance gate for staging refs (default on, min confidence 0.60)
#HUB_NEWS_RELEVANCE_GATE=1
#HUB_NEWS_RELEVANCE_MIN_CONFIDENCE=0.60
#HUB_NEWS_RELEVANCE_RULE_FIRST=1
# Override LLM Wiki app-state path for embedding config (macOS default below)
#LLM_WIKI_APP_STATE_PATH=~/Library/Application Support/com.llmwiki.app/app-state.json

# NSE browser fetch module (nodriver + MiniMax agent)
#NSE_BROWSER_AUTO_INSTALL_CHROME=1
#NSE_BROWSER_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Headed browser (NSE blocks repeated open/close — use one session per backfill batch)
#NSE_BROWSER_HEADLESS=0
#NSE_BROWSER_MIN_INTERVAL_S=180
#NSE_BROWSER_INTRA_MISSION_INTERVAL_S=1
#NSE_BROWSER_PAGE_WAIT_S=0.8
#NSE_BROWSER_MISSION_TIMEOUT_S=55
#NSE_BROWSER_HISTORICAL_TIMEOUT_S=120
#NSE_BROWSER_ALLOW_DOWNLOAD_CLICK=0
#NSE_BROWSER_DOWNLOAD_TIMEOUT_S=25
#NSE_BROWSER_AGENT_VISION=0
#NSE_BROWSER_AGENT_MODEL=MiniMax-M3
#NSE_BROWSER_ON_REFRESH=1
#NSE_BROWSER_WEB_FLOW_ON_REFRESH=1
#NSE_BROWSER_WEB_FLOW_BROWSER=0
#WEB_FLOW_MONTHS_BACK=18
#NSE_BROWSER_WEB_FLOW_TIMEOUT_S=120
#NSE_BROWSER_AGENT_DISABLED=0
# Rescue chain: nodriver deterministic → MiniMax operator → MiniMax extract
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Local SearXNG instance for news search (used by the news aggregator)
#SEARXNG_BASE_URL=http://localhost:5556
#SEARXNG_NEWS_ENGINES=bing
# Bing news scraper disabled in stack/searxng/settings.yml (empty-document bot blocks).
# DuckDuckGo disabled until CAPTCHA cleared on container IP — see docs.searxng.org/admin/answer-captcha.html
#SEARXNG_DEFAULT_LANG=en-IN
#SEARXNG_NEWS_ENGINES=bing
#SEARXNG_PROBE_ENGINES=bing
#SEARXNG_FINANCE_ENGINES=bing
#SEARXNG_WEB_ENGINES=bing
