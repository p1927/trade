{
  "mcpServers": {
    "openalgo": {
      "command": "{{OPENALGO_MCP_WRAPPER}}",
      "args": [
        "{{OPENALGO_API_KEY}}",
        "{{OPENALGO_HOST}}"
      ],
      "toolTimeout": 60,
      "enabledTools": ["*"]
    },
    "skyvern": {
      "command": "{{SKYVERN_MCP_WRAPPER}}",
      "args": [],
      "env": {
        "SKYVERN_BASE_URL": "{{SKYVERN_BASE_URL}}",
        "SKYVERN_API_KEY": "{{SKYVERN_API_KEY}}",
        "SKYVERN_API_PREFIX": "{{SKYVERN_API_PREFIX}}"
      },
      "toolTimeout": 120,
      "enabledTools": ["*"]
    }
  }
}
