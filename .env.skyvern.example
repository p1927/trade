# Skyvern Docker env — copy to .env.skyvern and fill LLM keys.
# Reuse OPENAI_API_KEY or ANTHROPIC_API_KEY from repo root .env.

ENABLE_OPENAI=true
LLM_KEY=OPENAI_GPT4O
OPENAI_API_KEY=

# Alternative: Anthropic
# ENABLE_ANTHROPIC=true
# LLM_KEY=ANTHROPIC_CLAUDE4_SONNET
# ANTHROPIC_API_KEY=

BROWSER_TYPE=chromium-headful
BROWSER_STREAMING_MODE=cdp

# Optional: OpenRouter / Groq
# ENABLE_OPENROUTER=true
# LLM_KEY=OPENROUTER
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
