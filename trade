#!/usr/bin/env bash
# Trade stack CLI — one entry point for stack, tunnels, webhooks, and research.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
trade — Trade stack command-line interface

Usage:
  trade <command> [subcommand] [options]

Stack (one lifecycle — use these):
  up                    Start background stack (preflight + heal)
  heal                  Heal missing services only (no preflight noise)
  down [--all|--hub]          Stop OpenAlgo + Vibe + watchers; remove stale pidfiles/claims ( --all: + docker compose down + tunnels )
  heal [--hub-only]           Heal missing services (hub tier only with --hub-only)
  restart [--force]     Heal missing services ( --force: full stop + start )
  status                Vibe + hub Docker health (read-only — does not start services)
  doctor                Preflight checks before start (no start)
  dev                   Dev mode: auto-reload API/UI + OpenAlgo debug (exclusive Vibe tier).
                        Nautilus watch keeps running; use trade reload nautilus after handoff changes.
  reload [target]       Reload after code/env change (app|env|nautilus|hub|all)
  start [mode]          Legacy foreground modes (prefer trade up / trade dev)
                        Modes: vibe | openalgo | cli | full | daemon | nautilus-watch
  stop [--all]          Alias for down
  status-vibe           Alias for status
  status-hub            Hub Docker tier only
  stop-docker [target]  Stop hub Docker: searxng | timescale | redis | all | down
  stop-searxng          Stop SearXNG Docker only (alias for stop-docker searxng)
  logs-searxng          Follow SearXNG logs
  sync-ports            Apply stack/ports.yaml to .env files

Tunnel (webhook exposure):
  tunnel quick          Start trycloudflare.com tunnel (dev/testing)
  tunnel restart        Stop and restart quick tunnel; print working URL
  tunnel named          Start persistent Cloudflare named tunnel
  tunnel stop           Stop active tunnel
  tunnel status         Show tunnel + HOST_SERVER state
  tunnel sync [url]     Set openalgo/.env HOST_SERVER
  tunnel urls [plat]    Print webhook URLs (tradingview|gocharting|chartink|all)

Webhooks (shortcut):
  webhooks [platform]   Same as tunnel urls + setup hints

Research:
  research <ticker>     Run company research pipeline (e.g. RELIANCE, AAPL)
  research <ticker> --days 30

Data (historic / prediction cold tier):
  data ingest [--offline] [--incremental] [--audit]   Load historic_data + cold tier
  data audit [--write]                              Prediction factor coverage audit
  sim-data extend [--dry-run]                       Append-only HF NIFTY replay extend

Tiered APIs (queue + hub cache):
  tiered-api status [--json]   Per-source daily budget, queue depth, config

Data router (unified fetch + backlog worker):
  data-router status [--json]  Backlog depth, worker heartbeat, tiered budgets
  data-worker [--once]         Drain tiered/NSE mission backlog (background daemon via TRADE_DATA_WORKER=1)

Maintenance:
  sync [target]         Sync submodules (all|tradingagents|openalgo|status)
  sync-ports            Apply stack/ports.yaml to .env, compose, OpenAlgo/Vibe
  setup [target]        Bootstrap deps on a fresh machine (all|vibe|verify)
  setup vibe            Wire OpenAlgo MCP into Vibe agent config

Examples:
  trade setup                       # fresh machine — install all deps + verify
  trade setup verify                # re-check without installing
  trade up                          # background stack (recommended)
  trade heal                        # start only what's down (quiet heal)
  trade doctor && trade up          # verify deps, then start
  trade restart                     # heal — start only what's down
  trade restart --force             # full stop + preflight + start
  trade down                        # stop background stack
  trade dev                         # dev mode with auto-reload (blocks trade up; Nautilus watch stays up)
  trade reload app                  # reload daemon after code edit
  trade start openalgo              # OpenAlgo only (webhook setup)
  trade start nautilus-watch --agent-id aa_abc123
  trade tunnel quick                # expose OpenAlgo to the internet
  trade status                      # is everything up?
  trade research RELIANCE

Approved channels (do not kill stack ports ad hoc):
  Start/heal background stack   trade up | trade heal
  Full reset                    trade restart --force
  Heal missing only             trade restart
  Stop everything               trade down
  Dev with HMR                  trade dev
  Reload after code (daemon)    trade reload app
  Reload after .env             trade reload env
  Reload Nautilus only          trade reload nautilus
  OpenAlgo only (background)    trade start openalgo

Legacy: ./start.sh (foreground), make start-daemon → trade up
EOF
}

webhook_hints() {
  local platform="${1:-all}"
  case "$platform" in
    tradingview|all)
      cat <<'EOF'

TradingView — where to paste the webhook URL:
  1. Open your chart → Create Alert
  2. Notifications tab → enable "Webhook URL"
  3. Paste the URL into Webhook URL
  4. Paste the JSON from OpenAlgo /tradingview into Message
  5. OpenAlgo UI: http://127.0.0.1:5001/tradingview
EOF
      ;;
  esac
  case "$platform" in
    gocharting|all)
      cat <<'EOF'

GoCharting — where to paste the webhook URL:
  1. Create alert on your chart (Premium required)
  2. Paste URL into webhook field
  3. Paste JSON from OpenAlgo /gocharting into alert message
  4. OpenAlgo UI: http://127.0.0.1:5001/gocharting
EOF
      ;;
  esac
  case "$platform" in
    chartink|all)
      cat <<'EOF'

Chartink — where to paste the webhook URL:
  1. Create scanner alert → Webhook URL field
  2. Body: {"webhook_id": "<id>", "stocks": "{stocks}"}
  3. Create strategy in OpenAlgo /chartink to get webhook-id
  4. OpenAlgo UI: http://127.0.0.1:5001/chartink
EOF
      ;;
  esac
}

_stack_trade_prelude() {
  local cmd="$1"
  # shellcheck disable=SC1091
  source "$ROOT/scripts/stack_lib.sh"
  STACK_ROOT="$ROOT"
  stack_load_env
  stack_maybe_heal_before_command "$cmd"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  up)
    _stack_trade_prelude up
    exec "$ROOT/scripts/stack_ctl.sh" up "$@"
    ;;

  heal)
    _stack_trade_prelude heal
    exec "$ROOT/scripts/stack_ctl.sh" ensure "$@"
    ;;

  down)
    _stack_trade_prelude down
    exec "$ROOT/scripts/stack_ctl.sh" down "$@"
    ;;

  start)
    _stack_trade_prelude start
    mode="${1:-vibe}"
    shift || true
    case "$mode" in
      vibe|default)     exec "$ROOT/start.sh" "$@" ;;
      openalgo)         exec "$ROOT/start.sh" --openalgo-only --daemon "$@" ;;
      cli|agents)       exec "$ROOT/start.sh" --cli "$@" ;;
      full)             exec "$ROOT/start.sh" "$@" ;;
      daemon)
        echo "[trade] note: 'trade start daemon' is an alias for 'trade up'" >&2
        exec "$ROOT/scripts/stack_ctl.sh" up "$@"
        ;;
      nautilus-watch)
        # shellcheck disable=SC1091
        STACK_ROOT="$ROOT"
        source "$ROOT/scripts/stack_lib.sh"
        stack_load_env
        stack_start_nautilus_watch "$@"
        ;;
      -h|--help|help)
        echo "Usage: trade start nautilus-watch [--agent-id aa_...]"
        ;;
      *)
        echo "Unknown start mode: $mode (try: vibe, openalgo, cli, full)" >&2
        exit 1
        ;;
    esac
    ;;

  status)
    _stack_trade_prelude status
    exec "$ROOT/scripts/stack_ctl.sh" status "$@"
    ;;

  status-vibe)
    _stack_trade_prelude status
    exec "$ROOT/scripts/stack_ctl.sh" status "$@"
    ;;

  status-hub)
    _stack_trade_prelude status-hub
    exec "$ROOT/scripts/status_hub_stack.sh" "$@"
    ;;

  doctor)
    exec "$ROOT/scripts/stack_doctor.sh" "$@"
    ;;

  dev)
    _stack_trade_prelude dev
    exec "$ROOT/scripts/stack_dev.sh" "$@"
    ;;

  reload)
    _stack_trade_prelude reload
    exec "$ROOT/scripts/reload_vibe_stack.sh" "$@"
    ;;

  restart)
    _stack_trade_prelude restart
    exec "$ROOT/scripts/stack_ctl.sh" restart "$@"
    ;;

  stop)
    exec "$ROOT/scripts/stack_ctl.sh" down "$@"
    ;;

  stop-docker)
    target="${1:-all}"
    shift || true
    # shellcheck disable=SC1091
    source "$ROOT/scripts/stack_lib.sh"
    STACK_ROOT="$ROOT"
    stack_load_env
    case "$target" in
      searxng)    stack_docker_stop_searxng "$@" ;;
      timescale)  stack_docker_stop_service timescaledb "$@" ;;
      redis)      stack_docker_stop_redis "$@" ;;
      all)        stack_docker_stop_all "$@" ;;
      down)       stack_docker_down_all "$@" ;;
      -h|--help|help)
        echo "Usage: trade stop-docker [searxng|timescale|redis|all|down]"
        exit 0
        ;;
      *)
        echo "Unknown stop-docker target: $target (try: searxng, timescale, redis, all, down)" >&2
        exit 1
        ;;
    esac
    ;;

  stop-searxng)
    # shellcheck disable=SC1091
    source "$ROOT/scripts/stack_lib.sh"
    STACK_ROOT="$ROOT"
    stack_load_env
    stack_docker_stop_searxng "$@"
    ;;

  logs-searxng)
    exec docker compose -f "$ROOT/docker-compose.stack.yml" logs -f searxng "$@"
    ;;

  tunnel|expose)
    sub="${1:-}"
    shift || true
    case "$sub" in
      quick)    exec "$ROOT/exposure/start.sh" quick "$@" ;;
      restart)  exec "$ROOT/exposure/start.sh" restart "$@" ;;
      named)    exec "$ROOT/exposure/start.sh" named "$@" ;;
      stop)    exec "$ROOT/exposure/start.sh" stop "$@" ;;
      status)  exec "$ROOT/exposure/start.sh" status "$@" ;;
      sync)    exec "$ROOT/exposure/start.sh" sync "$@" ;;
      urls)
        platform="${1:-all}"
        shift || true
        exec "$ROOT/exposure/start.sh" urls "$platform" "$@"
        ;;
      -h|--help|help|"")
        exec "$ROOT/exposure/start.sh" --help
        ;;
      *)
        echo "Unknown tunnel command: $sub (try: quick, restart, named, stop, status, sync, urls)" >&2
        exit 1
        ;;
    esac
    ;;

  webhooks|webhook)
    platform="${1:-all}"
    shift || true
    "$ROOT/exposure/start.sh" urls "$platform" "$@" || true
    webhook_hints "$platform"
    ;;

  research)
    _stack_trade_prelude research
    ticker="${1:-}"
    if [[ -z "$ticker" || "$ticker" == "-h" || "$ticker" == "--help" ]]; then
      echo "Usage: trade research <ticker> [--days N] [--json]"
      exit 0
    fi
    shift || true
    py="$ROOT/.venv/bin/python"
    [[ -x "$py" ]] || py="python3"
    exec "$py" "$ROOT/scripts/run_company_research.py" "$ticker" "$@"
    ;;

  data)
    _stack_trade_prelude data
    sub="${1:-}"
    shift || true
    py="$ROOT/.venv/bin/python"
    [[ -x "$py" ]] || py="python3"
    case "$sub" in
      ingest)
        exec "$py" "$ROOT/scripts/ingest_historical_data.py" "$@"
        ;;
      audit)
        args=()
        if [[ "${1:-}" == "--write" ]]; then
          args+=(--write)
          shift || true
        fi
        exec "$py" "$ROOT/scripts/audit_prediction_data.py" "${args[@]}" "$@"
        ;;
      -h|--help|help|"")
        cat <<'EOF'
Usage:
  trade data ingest [--offline] [--incremental] [--incremental-days N] [--audit]
  trade data audit [--write]
EOF
        ;;
      *)
        echo "Unknown data subcommand: $sub (try: ingest, audit)" >&2
        exit 1
        ;;
    esac
    ;;

  sim-data)
    _stack_trade_prelude sim-data
    sub="${1:-extend}"
    shift || true
    py="$ROOT/.venv/bin/python"
    [[ -x "$py" ]] || py="python3"
    case "$sub" in
      extend)
        exec "$py" "$ROOT/scripts/extend_hf_replay.py" "$@"
        ;;
      -h|--help|help|"")
        cat <<'EOF'
Usage:
  trade sim-data extend [--dry-run] [--index-only] [--options-only]
EOF
        ;;
      *)
        echo "Unknown sim-data subcommand: $sub (try: extend)" >&2
        exit 1
        ;;
    esac
    ;;

  tiered-api)
    _stack_trade_prelude tiered-api
    sub="${1:-status}"
    shift || true
    py="$ROOT/.venv/bin/python"
    [[ -x "$py" ]] || py="python3"
    case "$sub" in
      status)
        exec "$py" "$ROOT/scripts/tiered_api_status.py" "$@"
        ;;
      -h|--help|help|"")
        echo "Usage: trade tiered-api status [--json]"
        ;;
      *)
        echo "Unknown tiered-api subcommand: $sub (try: status)" >&2
        exit 1
        ;;
    esac
    ;;

  data-router)
    _stack_trade_prelude data-router
    sub="${1:-status}"
    shift || true
    py="$ROOT/.venv/bin/python"
    [[ -x "$py" ]] || py="python3"
    case "$sub" in
      status)
        exec "$py" "$ROOT/scripts/data_router_status.py" "$@"
        ;;
      -h|--help|help|"")
        echo "Usage: trade data-router status [--json]"
        ;;
      *)
        echo "Unknown data-router subcommand: $sub (try: status)" >&2
        exit 1
        ;;
    esac
    ;;

  data-worker)
    py="$ROOT/.venv/bin/python"
    [[ -x "$py" ]] || py="python3"
    exec "$py" "$ROOT/scripts/data_router_worker.py" "$@"
    ;;

  sync)
    target="${1:-all}"
    shift || true
    exec "$ROOT/scripts/sync.sh" "$target" "$@"
    ;;

  sync-ports)
    py="$ROOT/.venv/bin/python"
    [[ -x "$py" ]] || py="python3"
    exec "$py" "$ROOT/scripts/sync_stack_ports.py" --apply "$@"
    ;;

  setup)
    sub="${1:-all}"
    shift || true
    case "$sub" in
      all|"")
        exec bash "$ROOT/scripts/setup_trade_stack.sh" "$@"
        ;;
      verify)
        exec bash "$ROOT/scripts/setup_trade_stack.sh" --verify-only "$@"
        ;;
      vibe)
        py="$ROOT/.venv/bin/python"
        [[ -x "$py" ]] || py="python3"
        exec "$py" "$ROOT/scripts/setup_vibe.py" "$@"
        ;;
      -h|--help|help|"")
        cat <<'EOF'
Usage:
  trade setup              Full stack bootstrap (venv, ML, OpenAlgo, frontend, verify)
  trade setup verify       Run trade doctor checks only
  trade setup vibe         Sync ~/.vibe-trading operator config only
EOF
        ;;
      *)
        echo "Unknown setup target: $sub (try: all, verify, vibe)" >&2
        exit 1
        ;;
    esac
    ;;

  -h|--help|help|"")
    usage
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
